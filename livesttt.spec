    a.scripts,
    a.binaries,
    a.zipfiles,
    a.datas,
    [],
    name='livesttt',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    upx_exclude=['pywintypes*.dll', 'vcruntime*.dll'],
